{
  "study_id": "pinn_phase1_variant_a_gradient_balance",
  "data": {
    "dataset_root": "datasets/phase1_singlezone"
  },
  "model": {
    "hidden_dim": 64,
    "depth": 3,
    "dropout": 0.0
  },
  "training": {
    "seed": 42,
    "device": "cpu",
    "batch_size": 256,
    "epochs": 150,
    "patience": 20,
    "learning_rate": 0.001,
    "weight_decay": 1e-05,
    "lambda_physics": 0.005,
    "loss_weighting": {
      "mode": "gradient_balance",
      "gradient_balance": {
        "ema_beta": 0.95,
        "lambda_min": 1e-06,
        "lambda_max": "1.0e2",
        "target_ratio": 1.0
      }
    }
  }
}