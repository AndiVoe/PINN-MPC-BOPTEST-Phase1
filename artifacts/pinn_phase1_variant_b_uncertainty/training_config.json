{
  "study_id": "pinn_phase1_variant_b_uncertainty",
  "data": {
    "dataset_root": "datasets/phase1_singlezone"
  },
  "model": {
    "hidden_dim": 64,
    "depth": 3,
    "dropout": 0.1
  },
  "training": {
    "seed": 42,
    "device": "cpu",
    "batch_size": 256,
    "epochs": 150,
    "patience": 20,
    "learning_rate": 0.001,
    "weight_decay": 1e-05,
    "lambda_physics": 0.01,
    "loss_weighting": {
      "mode": "uncertainty",
      "uncertainty": {
        "init_log_sigma_data": 0.0,
        "init_log_sigma_physics": 0.0
      }
    }
  }
}